# Supabase (projeto dayone-verify — ID: ydvjtgvrbajarrefcfdl)
# Formato: postgresql+asyncpg://postgres.[project-ref]:[senha]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Alembic usa conexão direta (não o pooler)
# Formato: postgresql+asyncpg://postgres:[senha]@db.ydvjtgvrbajarrefcfdl.supabase.co:5432/postgres
DIRECT_URL=

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 (bucket dayone-verify-docs)
# Endpoint formato: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=dayone-verify-docs

# App
APP_ENV=staging
# Segredo para rotas /api/internal chamadas pelo n8n (gere com: openssl rand -hex 32)
INTERNAL_API_SECRET=
